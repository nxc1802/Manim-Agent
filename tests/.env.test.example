# Copy to `tests/.env.test` (gitignored). Loaded by `tests/conftest.py` before tests run.
# These keys are NOT part of `backend.core.config.Settings` — integration tests read `os.environ` directly.

# Postgres RLS integration (`pytest tests/integration -m integration`)
POSTGRES_RLS_TEST_URL=postgresql://postgres:postgres@127.0.0.1:5432/rls_test
