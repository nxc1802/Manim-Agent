# Public browser configuration. Never add SUPABASE_SERVICE_ROLE_KEY here.
VITE_API_BASE_URL=http://localhost:8000/v1
VITE_WS_BASE_URL=ws://localhost:8000/v1
# Matches the local Backend example. Production must switch this to `jwt` and
# provide the two public Supabase values below.
VITE_AUTH_MODE=off
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
