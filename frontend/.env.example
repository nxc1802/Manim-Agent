# Public browser configuration. Never add SUPABASE_SECRET_KEY or a legacy
# service-role key here.
VITE_API_BASE_URL=http://localhost:8000/v1
VITE_WS_BASE_URL=ws://localhost:8000/v1
# Vercel production must use the absolute protected Space endpoint for both:
# https://<space>.hf.space/v1 (the client converts HTTPS to WSS for sockets).
# Matches the local Backend example. Production must switch this to `jwt` and
# provide the two public Supabase values below.
VITE_AUTH_MODE=off
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use VITE_SUPABASE_ANON_KEY instead.
