# Copy to `.env` (gitignored). Chỉ giữ biến cần cho chạy thật / CI.

# Redis (API + Celery)
REDIS_URL=redis://localhost:6379/0

# LLM — OpenRouter (LiteLLM)
OPENROUTER_API_KEY=
LLM_MODE=auto
# LLM_API_BASE=https://openrouter.ai/api/v1
# AGENT_MODELS_YAML=

# E2E release gate (pytest -m e2e_llm)
# E2E_LLM=1

# Auth
AUTH_MODE=off
DEV_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUDIENCE=authenticated

# Supabase mirror (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Worker image tags (enqueue preview / voice)
WORKER_IMAGE_TAG=
TTS_WORKER_IMAGE_TAG=

# Celery (defaults follow REDIS_URL)
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# Integration tests only
# POSTGRES_RLS_TEST_URL=

# CORS (optional)
# CORS_ORIGINS=
