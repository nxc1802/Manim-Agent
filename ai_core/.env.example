# AI Core only: Google provider credentials, rendering and its authenticated Backend URL.
APP_ENV=development
BACKEND_INTERNAL_URL=http://localhost:8000/internal
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
READINESS_TIMEOUT_SECONDS=3
AI_STEP_SOFT_TIME_LIMIT_SECONDS=1800
AI_STEP_TIME_LIMIT_SECONDS=1890
RENDER_SOFT_TIME_LIMIT_SECONDS=3900
RENDER_TIME_LIMIT_SECONDS=4000
CELERY_VISIBILITY_TIMEOUT_SECONDS=7200
CELERY_MAX_TASKS_PER_CHILD=10
INTERNAL_SERVICE_TOKEN=change-me-in-production

# A comma-separated key pool is supported; GOOGLE_API_KEY_1, _2, ... also work.
GOOGLE_API_KEY=
# GOOGLE_API_KEY_1=
# GOOGLE_API_KEY_2=

# Worker stages local file:// artifacts; Backend uploads/signs durable objects.
ARTIFACTS_DIR=/artifacts
MANIM_MEMORY_LIMIT_MB=2048
MANIM_CPU_LIMIT_SECONDS=300
MANIM_TIMEOUT_SECONDS=3600
TTS_TIMEOUT_SECONDS=120
CONCAT_DOWNLOAD_TIMEOUT_SECONDS=120
CONCAT_SOURCE_MAX_BYTES=1073741824
