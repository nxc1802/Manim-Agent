# Copy to `.env` (gitignored). Any key not set here uses defaults in `backend/core/config.py` (class `Settings`).

# Redis (API + Celery; broker/result default to this URL when unset)
REDIS_URL=redis://localhost:6379/0

# LLM: leave empty for offline FakeLLM; set for LiteLLM / OpenRouter
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=

# Google AI Studio API key configurations for rotation:
# Method 1 (Default): Comma-separated list of keys
GOOGLE_API_KEY=

# Method 2: Suffix-based indexed keys (active if GOOGLE_API_KEY is not defined)
# GOOGLE_API_KEY_1=
# GOOGLE_API_KEY_2=
# GOOGLE_API_KEY_3=

# API Bases (optional, defaults to standard endpoints)
# LLM_API_BASE=https://openrouter.ai/api/v1  # Global fallback
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# DASHSCOPE_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# AUTH_MODE=jwt
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUDIENCE=authenticated
# DEV_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_SIGNED_URL_SECONDS=
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
# Paths / Manim / workers (defaults in Settings): MANIM_SCENE_FILE, MANIM_SCENE_CLASS,
# OUTPUT_DIR, REPO_ROOT, GENERATED_SCENE_CLASS, MAX_MANIM_CODE_BYTES, WORKER_NAME,
# WORKER_IMAGE_TAG, TTS_WORKER_NAME, TTS_WORKER_IMAGE_TAG
# CORS_ORIGINS=
# APP_ENV=
#
# Logging (HF Space / Docker: set as Space variables or container env)
# PIPELINE_LOG_LEVEL=INFO   # JSON pipeline lines: use INFO (default) or DEBUG for extra pipeline_debug.* lines
# UVICORN_LOG_LEVEL=info    # HTTP/server noise: info (default) or debug
# CELERY_LOG_LEVEL=INFO     # Worker subprocess only: INFO or DEBUG
#
# Test-only env (Postgres RLS, etc.): see tests/.env.test.example — not read by the API.
