# Backend only: API, authentication, database persistence, HITL state and queue dispatch.
APP_ENV=development
AUTH_MODE=off
CORS_ORIGINS=http://localhost:5173
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=manim
REDIS_MAX_CONNECTIONS=10

# Must match ai_core/.env. Rotate this value in every non-development environment.
INTERNAL_SERVICE_TOKEN=change-me-in-production
AI_CORE_URL=http://localhost:8001

# Backend owns database credentials. Never put these values in ai_core/.env.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=videos
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
