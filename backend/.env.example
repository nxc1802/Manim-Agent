# Backend only: API, authentication, database persistence, HITL state and queue dispatch.
APP_ENV=development
AUTH_MODE=off
CORS_ORIGINS=http://localhost:5173
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=manim
REDIS_MAX_CONNECTIONS=10
PIPELINE_LOCK_TIMEOUT_SECONDS=300
PIPELINE_LOCK_BLOCKING_SECONDS=10
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60
CACHE_LIST_TTL_SECONDS=30
CACHE_NEGATIVE_TTL_SECONDS=5
CACHE_GENERATION_TTL_SECONDS=86400
WEBSOCKET_REDIS_RECONNECT_MAX_SECONDS=5
READINESS_CACHE_SECONDS=10
READINESS_TIMEOUT_SECONDS=2
AI_STEP_STALE_AFTER_SECONDS=1920
AI_STEP_QUEUE_STALE_AFTER_SECONDS=180

# Must match ai_core/.env. Rotate this value in every non-development environment.
INTERNAL_SERVICE_TOKEN=change-me-in-production

# Backend owns database credentials. Never put these values in ai_core/.env.
SUPABASE_URL=
# Prefer the current key format. SUPABASE_SERVICE_ROLE_KEY remains accepted
# as a legacy alias during migration.
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=videos
SUPABASE_SIGNED_URL_SECONDS=3600
INTERNAL_RENDER_SIGNED_URL_SECONDS=900
# Leave this blank for current ES256/RS256 signing keys resolved through JWKS.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_CACHE_SECONDS=300
SUPABASE_JWT_AUDIENCE=authenticated
